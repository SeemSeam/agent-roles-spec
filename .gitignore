# Hidden local/runtime state
# Dot-prefixed files and folders are local by default. Project-owned hidden
# files/dirs are explicitly re-included below.
.*
!.gitignore
!.npmignore
!.github/
!.github/**

# CCB internal config and runtime
.ccb/

# OS/editor
.DS_Store
Thumbs.db
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/

# Node/tooling
node_modules/
dist/
build/

# Runtime/state that must not enter RolePacks
*.pid
*.sock
sessions/
conversation-logs/
provider-state/
provider-runtime/

# Secrets
.env
.env.*
*.pem
*.key
*.p12
*.pfx

# Private outreach drafts
docs/outreach/agent-roles-introduction-letter.md
docs/outreach/agent-roles-introduction-letter.en.md
