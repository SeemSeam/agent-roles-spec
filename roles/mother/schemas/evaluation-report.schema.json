{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-roles.local/schemas/mother/evaluation-report.schema.json",
  "title": "Mother Evaluation Report",
  "type": "object",
  "required": [
    "schema",
    "role_id",
    "version",
    "catalog_level",
    "source_path",
    "evaluation_date",
    "checks",
    "behavior_fixtures",
    "findings",
    "recommendation"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "agent-roles/mother-evaluation-report/v1"
    },
    "role_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "catalog_level": {
      "enum": ["experimental", "preview", "stable", "deprecated"]
    },
    "source_path": {
      "type": "string",
      "minLength": 1
    },
    "evaluation_date": {
      "type": "string",
      "format": "date"
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "result", "evidence"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "enum": ["pass", "fail", "not_run", "blocked"]
          },
          "evidence": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "behavior_fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "realistic_prompt",
          "expected_behavior",
          "negative_prompt",
          "expected_negative_behavior"
        ],
        "additionalProperties": false,
        "properties": {
          "realistic_prompt": {
            "type": "string",
            "minLength": 1
          },
          "expected_behavior": {
            "type": "string",
            "minLength": 1
          },
          "negative_prompt": {
            "type": "string",
            "minLength": 1
          },
          "expected_negative_behavior": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "findings": {
      "type": "object",
      "required": ["blockers", "major", "minor", "suggestions"],
      "additionalProperties": false,
      "properties": {
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "major": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "minor": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "suggestions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "recommendation": {
      "type": "object",
      "required": ["publication", "residual_risks", "human_review_required"],
      "additionalProperties": false,
      "properties": {
        "publication": {
          "enum": ["ready", "ready_with_risks", "blocked", "draft_only"]
        },
        "residual_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "human_review_required": {
          "type": "boolean"
        }
      }
    }
  }
}
